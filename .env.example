# ============================================================
# Claudeagent01 — Slack Knowledge Base Plugin
# Copy to .env and fill in. Never commit .env.
# ============================================================

# --- Slack App (Socket Mode) ---
# From: https://api.slack.com/apps → Your App → Basic Information
SLACK_APP_TOKEN=xapp-1-...              # App-Level Token (connections:write scope)
SLACK_BOT_TOKEN=xoxb-...                # Bot User OAuth Token
SLACK_SIGNING_SECRET=...                # Signing Secret (defense in depth)

# --- Supabase ---
# From: https://supabase.com/dashboard → Your Project → Project Settings → API
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...        # service_role key (server-side only)
SUPABASE_ANON_KEY=eyJ...                # optional, read-only fallback

# --- GitHub (for GitHub MCP) ---
# Personal Access Token (fine-grained, repo read/write)
GITHUB_TOKEN=ghp_...
GITHUB_REPO=skyblueearthjapan/Claudeagent01

# --- Vault path on VPS ---
# Absolute path to the knowledge/ folder (cloned GitHub repo)
VAULT_PATH=/opt/claudeagent01/knowledge

# --- Claude Code CLI ---
# Path to claude binary (usually set after `npm i -g @anthropic-ai/claude-code`)
CLAUDE_BIN=/usr/local/bin/claude

# --- Bot runtime ---
LOG_LEVEL=info                          # debug | info | warn | error
SESSION_TTL_MINUTES=60                  # idle timeout for Claude sessions per Slack thread
